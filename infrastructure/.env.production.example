# ============================================================
# Pharmacy One Stop - Production Environment Variables
# ============================================================
# Copy this file to .env.production and fill in actual values
# NEVER commit the actual .env.production file to git
# ============================================================

# --- App ---
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://pharmacyonestop.co.uk

# --- Database (PostgreSQL) ---
# If using Docker Compose local PostgreSQL:
POSTGRES_DB=pharmacy_one_stop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@postgres:5432/pharmacy_one_stop?schema=public
# If using RDS, override DATABASE_URL:
# DATABASE_URL=postgresql://p1s_admin:CHANGE_ME@p1s-production.xxxxx.eu-west-2.rds.amazonaws.com:5432/pharmacy_one_stop?schema=public&sslmode=require

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# --- JWT ---
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- AWS ---
AWS_REGION=eu-west-2
AWS_S3_BUCKET=pharmacy-one-stop-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# If using IAM roles on EC2, leave access keys blank

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Email (SMTP) ---
SMTP_HOST=email-smtp.eu-west-2.amazonaws.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@pharmacyonestop.co.uk

# --- Docker ---
DOCKER_REGISTRY=ghcr.io/justhamzaaa
IMAGE_TAG=latest
NEXT_PUBLIC_API_URL=https://pharmacyonestop.co.uk/api

# --- CloudFront (optional, for static asset CDN) ---
# NEXT_PUBLIC_CDN_URL=https://dxxxxxxxxx.cloudfront.net
